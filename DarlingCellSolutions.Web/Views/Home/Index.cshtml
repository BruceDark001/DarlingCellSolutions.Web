@model IEnumerable<DarlingCellSolutions.Domain.Entidades.Inventario.Producto>

@{
    ViewData["Title"] = "Inicio";
}

<!-- HERO -->

<section class="bg-dark text-white py-5">
    <div class="container">

        <div class="row align-items-center">

            <div class="col-md-6">

                <h1 class="display-4 fw-bold">
                    Darling Cell Solutions
                </h1>

                <p class="lead">
                    Especialistas en reparación de celulares,
                    venta de accesorios y repuestos originales.
                </p>

                <a asp-controller="Productos"
                   asp-action="Catalogo"
                   class="btn btn-primary btn-lg">

                    Ver Productos

                </a>

            </div>

            <div class="col-md-6 text-center">

                <img src="~/images/banner-celular.png"
                     class="img-fluid"
                     style="max-height:400px;" />

            </div>

        </div>

    </div>
</section>

<!-- PRODUCTOS -->

<section class="container py-5">

    <h2 class="text-center mb-4">
        Productos Destacados
    </h2>

    <div class="row">

        @foreach (var item in Model)
        {
            <div class="col-md-3 mb-4">

                <div class="card h-100 shadow">

                    <img src="~/images/no-image.png"
                         class="card-img-top"
                         style="height:220px;object-fit:contain;">

                    <div class="card-body">

                        <h5>@item.Nombre</h5>

                        <p>

                            S/. @item.PrecioVenta

                        </p>

                        <p>

                            Stock:
                            @item.Stock

                        </p>

                    </div>

                </div>

            </div>
        }

    </div>

</section>

<!-- SERVICIOS -->

<section class="bg-light py-5">

    <div class="container">

        <h2 class="text-center mb-5">

            Nuestros Servicios

        </h2>

        <div class="row text-center">

            <div class="col-md-3">


                <h5>Cambio de Pantalla</h5>

            </div>

            <div class="col-md-3">

                <h5>Cambio de Batería</h5>

            </div>

            <div class="col-md-3">


                <h5>Microsoldadura</h5>

            </div>

            <div class="col-md-3">


                <h5>Software</h5>

            </div>

        </div>

    </div>

</section>