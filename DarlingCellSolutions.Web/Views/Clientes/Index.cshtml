@model IEnumerable<DarlingCellSolutions.Domain.Entidades.Clientes.Cliente>

@{
    ViewData["Title"] = "Clientes";
}
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">

        @TempData["Success"]

        <button type="button"
                class="btn-close"
                data-bs-dismiss="alert">
        </button>

    </div>
}

<div class="card shadow">

    <div class="card-header bg-primary text-white">

        <div class="row align-items-center">

            <div class="col-md-6">

                <h3 class="mb-0">
                    Gestión de Clientes
                </h3>

            </div>

            <div class="col-md-6 text-end">

                <a asp-action="Crear"
                   class="btn btn-light">

                    ➕ Nuevo Cliente

                </a>

            </div>

        </div>

    </div>


    <div class="card-body">

        <div class="row mb-3">

            <div class="col-md-4">

                <input type="text"
                       id="buscarCliente"
                       class="form-control"
                       placeholder="Buscar por DNI o Nombre..." />

            </div>

        </div>


        <table class="table table-striped table-hover"
               id="tablaClientes">

            <thead class="table-dark">

                <tr>

                    <th>DNI</th>

                    <th>Nombres</th>

                    <th>Apellidos</th>

                    <th>Teléfono</th>

                    <th class="text-center">
                        Acciones
                    </th>

                </tr>

            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    <tr>

                        <td>@item.Dni</td>

                        <td>@item.Nombres</td>

                        <td>@item.Apellidos</td>

                        <td>@item.Telefono</td>

                        <td class="text-center">

                            <a asp-action="Editar"
                               asp-route-id="@item.Id"
                               class="btn btn-warning btn-sm">

                                ✏ Editar

                            </a>

                            <a asp-action="Detalles"
                               asp-route-id="@item.Id"
                               class="btn btn-info btn-sm">

                                👁 Ver

                            </a>

                            <a asp-action="Eliminar"
                               asp-route-id="@item.Id"
                               class="btn btn-danger btn-sm"
                               onclick="return confirm('¿Desea eliminar este cliente?');">

                                🗑 Eliminar

                            </a>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>


@section Scripts {

    <script>

        document.getElementById("buscarCliente").addEventListener("keyup", function () {

            let filtro = this.value.toLowerCase();

            let filas = document.querySelectorAll("#tablaClientes tbody tr");

            filas.forEach(function(fila){

                let texto = fila.innerText.toLowerCase();

                fila.style.display = texto.includes(filtro) ? "" : "none";

            });

        });

    </script>

}