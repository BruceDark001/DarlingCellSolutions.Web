@model DarlingCellSolutions.Domain.Entidades.Seguridad.Usuario

<h2>Editar Usuario</h2>

<form asp-action="Editar" method="post">
    <input asp-for="Id" type="hidden" />

    <div class="row">

        <div class="col-md-6">

            <label>Nombres</label>

            <input asp-for="Nombres" class="form-control" />

        </div>

        <div class="col-md-6">

            <label>Apellidos</label>

            <input asp-for="Apellidos" class="form-control" />

        </div>

    </div>

    <br>

    <div class="row">

        <div class="col-md-4">

            <label>DNI</label>

            <input asp-for="Dni" class="form-control" />

        </div>

        <div class="col-md-4">

            <label>Teléfono</label>

            <input asp-for="Telefono" class="form-control" />

        </div>

        <div class="col-md-4">

            <label>Correo</label>

            <input asp-for="Correo" class="form-control" />

        </div>

    </div>

    <br>

    <div class="row">

        <div class="col-md-4">

            <label>Usuario</label>

            <input asp-for="NombreUsuario" class="form-control" />

        </div>

        <div class="col-md-4">

            <label>Contraseña</label>

            <input asp-for="PasswordHash"
                   type="password"
                   class="form-control" />

        </div>

        <div class="col-md-4">

            <label>Rol</label>

            <select asp-for="RolId"
                    asp-items="ViewBag.Roles"
                    class="form-select">
            </select>

        </div>

    </div>

    <br>

    <button class="btn btn-success">

        Guardar

    </button>

    <a asp-action="Index"
       class="btn btn-secondary">

        Cancelar

    </a>

</form>