@model IEnumerable<DarlingCellSolutions.Domain.Entidades.Clientes.Equipo>

<h2>Equipos</h2>

<a asp-action="Crear" class="btn btn-success mb-3">
    Nuevo Equipo
</a>

<table class="table table-bordered table-hover">

    <thead class="table-dark">
        <tr>
            <th>Cliente</th>
            <th>Marca</th>
            <th>Tipo</th>
            <th>Modelo</th>
            <th>IMEI</th>
            <th>Acciones</th>
        </tr>
    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>

                <td>@item.Cliente.Nombres</td>

                <td>@item.Marca.Nombre</td>

                <td>@item.TipoEquipo.Nombre</td>

                <td>@item.Modelo</td>

                <td>@item.IMEI</td>

                <td>

                    <a asp-action="Editar"
                       asp-route-id="@item.Id"
                       class="btn btn-warning btn-sm">

                        Editar

                    </a>

                    <a asp-action="Eliminar"
                       asp-route-id="@item.Id"
                       class="btn btn-danger btn-sm">

                        Eliminar

                    </a>

                </td>

            </tr>
        }

    </tbody>

</table>