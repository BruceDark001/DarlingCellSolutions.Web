@model IEnumerable<DarlingCellSolutions.Domain.Entidades.Inventario.Producto>

<h2>Productos</h2>

<a asp-action="Crear" class="btn btn-success mb-3">
    Nuevo Producto
</a>

<table class="table table-bordered table-striped">

    <thead class="table-dark">
        <tr>
            <th>Código</th>
            <th>Nombre</th>
            <th>Precio Venta</th>
            <th>Stock</th>
            <th></th>
        </tr>
    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>

                <td>@item.Codigo</td>

                <td>@item.Nombre</td>

                <td>@item.PrecioVenta</td>

                <td>@item.Stock</td>

                <td>

                    <a asp-action="Editar"
                       asp-route-id="@item.Id"
                       class="btn btn-warning btn-sm">
                        Editar
                    </a>

                    <a asp-action="Eliminar"
                       asp-route-id="@item.Id"
                       class="btn btn-danger btn-sm">
                        Eliminar
                    </a>

                </td>

            </tr>
        }

    </tbody>

</table>