@model DarlingCellSolutions.Domain.Entidades.Clientes.Cliente

@{
    ViewData["Title"] = "Detalle del Cliente";
}

<div class="card shadow">

    <div class="card-header bg-info text-white">

        <h3>Detalle del Cliente</h3>

    </div>

    <div class="card-body">

        <dl class="row">

            <dt class="col-sm-3">DNI</dt>
            <dd class="col-sm-9">@Model.Dni</dd>

            <dt class="col-sm-3">Nombres</dt>
            <dd class="col-sm-9">@Model.Nombres</dd>

            <dt class="col-sm-3">Apellidos</dt>
            <dd class="col-sm-9">@Model.Apellidos</dd>

            <dt class="col-sm-3">Teléfono</dt>
            <dd class="col-sm-9">@Model.Telefono</dd>

            <dt class="col-sm-3">Correo</dt>
            <dd class="col-sm-9">@Model.Correo</dd>

            <dt class="col-sm-3">Dirección</dt>
            <dd class="col-sm-9">@Model.Direccion</dd>

            <dt class="col-sm-3">Observaciones</dt>
            <dd class="col-sm-9">@Model.Observaciones</dd>

        </dl>

    </div>

    <div class="card-footer">

        <a asp-action="Editar"
           asp-route-id="@Model.Id"
           class="btn btn-warning">

            Editar

        </a>

        <a asp-action="Index"
           class="btn btn-secondary">

            Volver

        </a>

    </div>

</div>