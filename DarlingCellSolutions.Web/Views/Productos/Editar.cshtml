<input asp-for="Id" type="hidden" />
@model DarlingCellSolutions.Domain.Entidades.Inventario.Producto

<h2>Editar Producto</h2>

<form asp-action="Editar">

    <div class="mb-3">
        <label>Código</label>
        <input asp-for="Codigo" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Nombre</label>
        <input asp-for="Nombre" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Precio Compra</label>
        <input asp-for="PrecioCompra" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Precio Venta</label>
        <input asp-for="PrecioVenta" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Stock</label>
        <input asp-for="Stock" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Stock Mínimo</label>
        <input asp-for="StockMinimo" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Categoría Id</label>
        <input asp-for="CategoriaId" class="form-control" />
    </div>

    <button class="btn btn-success">
        Guardar
    </button>

    <a asp-action="Index" class="btn btn-secondary">
        Cancelar
    </a>

</form>