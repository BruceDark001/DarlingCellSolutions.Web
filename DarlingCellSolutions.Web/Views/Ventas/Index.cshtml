@{
    Layout = "_AdminLayout";
}

@model IEnumerable<DarlingCellSolutions.Domain.Entidades.Ventas.Venta>

<h2>Ventas</h2>

<a asp-action="Crear" class="btn btn-primary mb-3">
    Nueva Venta
</a>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Comprobante</th>
            <th>Fecha</th>
            <th>Total</th>
            <th width="120">Acciones</th>
        </tr>
    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.NumeroComprobante</td>
                <td>@item.FechaVenta.ToString("dd/MM/yyyy")</td>
                <td>S/. @item.Total.ToString("N2")</td>

                <td>
                    <a asp-action="Eliminar"
                       asp-route-id="@item.Id"
                       class="btn btn-danger btn-sm">
                        Eliminar
                    </a>
                </td>
            </tr>
        }

    </tbody>

</table>