@model IEnumerable<DarlingCellSolutions.Domain.Entidades.ServicioTecnico.OrdenServicio>

<h2>Órdenes de Servicio</h2>

<a asp-action="Crear" class="btn btn-success mb-3">
    Nueva Orden
</a>

<table class="table table-bordered">

    <thead>

        <tr>

            <th>N° Orden</th>

            <th>Cliente</th>

            <th>Equipo</th>

            <th>Estado</th>

            <th>Total</th>

            <th></th>

        </tr>

    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>

                <td>@item.NumeroOrden</td>

                <td>@item.Cliente.Nombres @item.Cliente.Apellidos</td>

                <td>@item.Equipo.Modelo</td>

                <td>@item.EstadoReparacion.Nombre</td>

                <td>S/. @item.TotalCobrado</td>

                <td>

                    <a asp-action="Editar" asp-route-id="@item.Id"
                       class="btn btn-warning btn-sm">

                        Editar

                    </a>

                </td>

            </tr>
        }

    </tbody>

</table>