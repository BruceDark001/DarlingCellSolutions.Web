@model DarlingCellSolutions.Web.Models.DashboardViewModel

<h2 class="mb-4">Dashboard</h2>

<div class="row">

    <div class="col-md-4 mb-3">
        <div class="card bg-primary text-white">
            <div class="card-body">
                <h5>Clientes</h5>
                <h2>@Model.TotalClientes</h2>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card bg-success text-white">
            <div class="card-body">
                <h5>Productos</h5>
                <h2>@Model.TotalProductos</h2>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card bg-warning text-dark">
            <div class="card-body">
                <h5>Órdenes</h5>
                <h2>@Model.TotalOrdenes</h2>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card bg-info text-white">
            <div class="card-body">
                <h5>Ventas</h5>
                <h2>@Model.TotalVentas</h2>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card bg-danger text-white">
            <div class="card-body">
                <h5>Stock Bajo</h5>
                <h2>@Model.StockBajo</h2>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card bg-dark text-white">
            <div class="card-body">
                <h5>Ingresos</h5>
                <h2>S/. @Model.IngresosTotales.ToString("N2")</h2>
            </div>
        </div>
    </div>

</div>