@{
    Layout = "_AdminLayout";
}

@model DarlingCellSolutions.Web.Models.DashboardViewModel

<h2 class="mb-4">Dashboard</h2>

<div class="row">

    <div class="col-md-4 mb-3">
        <div class="card bg-primary text-white">
            <div class="card-body">
                <h5>Clientes</h5>
                <h2>@Model.TotalClientes</h2>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card bg-success text-white">
            <div class="card-body">
                <h5>Productos</h5>
                <h2>@Model.TotalProductos</h2>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card bg-warning text-dark">
            <div class="card-body">
                <h5>Órdenes</h5>
                <h2>@Model.TotalOrdenes</h2>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card bg-info text-white">
            <div class="card-body">
                <h5>Ventas</h5>
                <h2>@Model.TotalVentas</h2>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card bg-danger text-white">
            <div class="card-body">
                <h5>Stock Bajo</h5>
                <h2>@Model.StockBajo</h2>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card bg-dark text-white">
            <div class="card-body">
                <h5>Ingresos</h5>
                <h2>S/. @Model.IngresosTotales.ToString("N2")</h2>
            </div>
        </div>
    </div>

    <hr />

    <div class="row">

        <div class="col-md-6">

            <h4>Productos con Stock Bajo</h4>

            <table class="table table-striped">

                <thead>

                    <tr>

                        <th>Producto</th>

                        <th>Stock</th>

                        <th>Mínimo</th>

                    </tr>

                </thead>

                <tbody>

                    @foreach (var p in Model.ProductosStockBajo)
                    {
                        <tr>

                            <td>@p.Nombre</td>

                            <td>@p.Stock</td>

                            <td>@p.StockMinimo</td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

        <div class="col-md-6">

            <h4>Últimas Ventas</h4>

            <table class="table table-striped">

                <thead>

                    <tr>

                        <th>Comprobante</th>

                        <th>Total</th>

                    </tr>

                </thead>

                <tbody>

                    @foreach (var v in Model.UltimasVentas)
                    {
                        <tr>

                            <td>@v.NumeroComprobante</td>

                            <td>S/. @v.Total.ToString("N2")</td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>